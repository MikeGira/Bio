{
  "version": 2,
  "functions": {
    "api/chat.js":           { "maxDuration": 60 },
    "api/db.js":             { "maxDuration": 30 },
    "api/analytics-auth.js": { "maxDuration": 10 },
    "api/send-digest.js":    { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/chat",            "dest": "/api/chat.js" },
    { "src": "/api/db",              "dest": "/api/db.js" },
    { "src": "/api/db\\?.*",         "dest": "/api/db.js" },
    { "src": "/analytics",           "dest": "/analytics.html" },
    { "src": "/api/analytics-auth",  "dest": "/api/analytics-auth.js" },
    { "src": "/api/send-digest",     "dest": "/api/send-digest.js" },
    { "src": "/(.*)",                "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/analytics",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}